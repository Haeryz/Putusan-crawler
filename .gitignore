# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
.uv-cache/
hermes-agent/

# Local credentials
.env
**/.env

# Crawler runtime state
.browser-profile/
# Ignore everything under downloads/ EXCEPT the raw-text extraction inputs, so a
# fresh clone can run the extractors without re-crawling. Source PDFs and run
# logs stay out of git (too large / not needed). Parent dirs are un-ignored so
# git can descend; their other contents are re-ignored just below.
downloads/*
!downloads/TPPO/
!downloads/kasus anak/
downloads/TPPO/*
!downloads/TPPO/raw-text/
downloads/kasus anak/*
!downloads/kasus anak/raw-text/

# LLM aggregation runtime state
LLM-aggregator/Anak/Deepseek/pause
LLM-aggregator/**/progress.jsonl
LLM-aggregator/**/logs/
LLM-aggregator/**/output/
LLM-aggregator/**/reports/
LLM-aggregator/**/last-codex-run.md
LLM-aggregator/**/.spans/

# Track the GPT extraction checkpoints + outputs so another device can pull the
# repo and resume the Codex run from where it left off. (These override the
# broad runtime-state ignores above.)
!LLM-aggregator/TPPO/GPT/progress.jsonl
!LLM-aggregator/Anak/GPT/progress.jsonl
!LLM-aggregator/TPPO/GPT/output/
!LLM-aggregator/TPPO/GPT/output/**
!LLM-aggregator/Anak/GPT/output/
!LLM-aggregator/Anak/GPT/output/**

# Generated artifacts and dependency installs
outputs/
node_modules/
**/node_modules/
